# Object files
*.o
*.obj

# Executables (ваши собранные программы)
*.exe
*.out
kol_dmiti        # имя вашего исполняемого файла
test_*           # любые тестовые исполняемые файлы

# Build directories (если используете CMake или просто папку build/)
build/
cmake-build-*/
bin/
obj/

# Static libraries (если будете собирать)
*.lib
*.a

# Shared libraries (динамические)
*.so
*.dll
*.dylib

# Debug symbols
*.dSYM/
*.pdb

# IDE files (чтобы не засорять репозиторий настройками)
.vscode/
.idea/
*.swp
*.swo

# OS junk
.DS_Store
Thumbs.db
